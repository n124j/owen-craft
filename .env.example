# Copy this file to .env and fill in your real Firebase values.
# .env is listed in .gitignore and must NEVER be committed.
# Get the values from the Firebase console (see FIREBASE_SETUP.md).
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=yourproject.firebaseapp.com
FIREBASE_DATABASE_URL=https://yourproject-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=yourproject
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
